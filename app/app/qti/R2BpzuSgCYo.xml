                <value>A</value>
            </correctResponse>
        </responseDeclaration>

        <itemBody>
            <choiceInteraction responseIdentifier="RESPONSE" maxChoices="1">
                <prompt>What does HTTP stand for?</prompt>

                <simpleChoice identifier="A">Hypertext Transfer Protocol</simpleChoice>
                <simpleChoice identifier="B">High Transfer Text Process</simpleChoice>
                <simpleChoice identifier="C">Host Tunnel Transfer Protocol</simpleChoice>
            </choiceInteraction>
        </itemBody>
